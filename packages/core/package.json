{
  "name": "@oimdb/core",
  "version": "3.8.0",
  "description": "Core in-memory data library with type-safe indices, reactive subscriptions, and event processing",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abaikov/oimdb.git"
  },
  "bugs": {
    "url": "https://github.com/abaikov/oimdb/issues"
  },
  "homepage": "https://github.com/abaikov/oimdb#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs",
    "test": "jest",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepack": "node -e \"require('fs').copyFileSync('../../llms.txt', 'llms.txt')\"",
    "prepublishOnly": "npm run type-check && npm test && npm run build"
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "keywords": [
    "oimdb",
    "in-memory",
    "database",
    "reactive",
    "typescript",
    "type-safe",
    "indices",
    "subscriptions",
    "event-processing",
    "state-management"
  ],
  "author": "Andrei Baikov",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsup": "^8.5.0",
    "typescript": "^5.2.2",
    "rimraf": "^5.0.5"
  }
}
