{
  "name": "@oimdb/exodra",
  "version": "0.1.0",
  "description": "Exodra integration for OIMDB - adapt reactive collections, indexes, objects and computeds into Exodra bindables",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abaikov/oimdb.git"
  },
  "bugs": {
    "url": "https://github.com/abaikov/oimdb/issues"
  },
  "homepage": "https://github.com/abaikov/oimdb#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts --tsconfig tsconfig.build.json",
    "test": "jest",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run type-check && npm test && npm run build"
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "peerDependencies": {
    "@exodra/reactivity": "^0.1.0",
    "@oimdb/core": "^3.8.0"
  },
  "devDependencies": {
    "@exodra/reactivity": "^0.1.0",
    "@types/jest": "^29.5.8",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "tsup": "^8.5.0",
    "typescript": "^5.2.2"
  },
  "keywords": [
    "oimdb",
    "exodra",
    "bindable",
    "reactive",
    "typescript",
    "state-management",
    "subscriptions",
    "selection"
  ],
  "author": "Andrei Baikov",
  "license": "MIT"
}
