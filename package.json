{
  "name": "oimdb",
  "version": "2.0.0",
  "description": "Deprecated umbrella package for OIMDB. Use @oimdb/core for collections, indexes, selectors, and DX factories.",
  "keywords": [
    "typescript",
    "library",
    "oim",
    "database",
    "oimdb",
    "state-management",
    "state-manager"
  ],
  "type": "module",
  "workspaces": [
    "packages/*",
    "website"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "deprecated": "This package has been split into scoped packages. Use @oimdb/core for collections, indexes, selectors, and DX factories.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abaikov/oimdb.git"
  },
  "bugs": {
    "url": "https://github.com/abaikov/oimdb/issues"
  },
  "homepage": "https://abaikov.github.io/oimdb/",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "build:core": "cd packages/core && npm run build",
    "build:react": "cd packages/react && npm run build",
    "build:async": "cd packages/async && npm run build",
    "build:persist": "cd packages/persist && npm run build",
    "build:snapshot-manager": "cd packages/snapshot-manager && npm run build",
    "build:redux-adapter": "cd packages/redux-adapter && npm run build",
    "build:devtools": "cd packages/devtools && npm run build",
    "build:mcp": "cd packages/mcp && npm run build",
    "bench": "tsx packages/core/scripts/run-bench.ts",
    "prepublishOnly": "npm test && npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts && eslint packages/core/src --ext .ts && eslint packages/react/src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix && eslint packages/core/src --ext .ts --fix && eslint packages/react/src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"packages/core/src/**/*.ts\" \"packages/react/src/**/*.ts\"",
    "clean": "rimraf dist packages/core/dist packages/react/dist packages/async/dist packages/persist/dist packages/snapshot-manager/dist packages/redux-adapter/dist",
    "docs:dev": "npm run start --workspace website",
    "docs:build": "npm run build --workspace website",
    "docs:serve": "npm run serve --workspace website",
    "install:packages": "cd packages/core && npm install && cd ../react && npm install",
    "publish:core": "npm publish --workspace @oimdb/core --access public",
    "publish:react": "npm publish --workspace @oimdb/react --access public",
    "publish:async": "npm publish --workspace @oimdb/async --access public",
    "publish:persist": "npm publish --workspace @oimdb/persist --access public",
    "publish:snapshot-manager": "npm publish --workspace @oimdb/snapshot-manager --access public",
    "publish:redux-adapter": "npm publish --workspace @oimdb/redux-adapter --access public",
    "publish:devtools": "npm publish --workspace @oimdb/devtools --access public",
    "publish:mcp": "npm publish --workspace @oimdb/mcp --access public",
    "publish:all": "npm run publish:core && npm run publish:react && npm run publish:async && npm run publish:persist && npm run publish:snapshot-manager && npm run publish:redux-adapter && npm run publish:devtools && npm run publish:mcp",
    "publish:rest": "npm run publish:react && npm run publish:async && npm run publish:persist && npm run publish:snapshot-manager && npm run publish:redux-adapter && npm run publish:devtools && npm run publish:mcp"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@oimdb/core": "^2.0.0"
  },
  "author": "Andrei Baikov",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.8.10",
    "@types/react": "^19.1.12",
    "@typescript-eslint/eslint-plugin": "^6.9.1",
    "@typescript-eslint/parser": "^6.9.1",
    "eslint": "^8.53.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "react": "^19.1.1",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.4",
    "typescript": "^5.2.2"
  }
}
